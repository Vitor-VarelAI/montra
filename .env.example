# Montra - variaveis de ambiente. Copia para .env e preenche.
# NUNCA committar o .env real.

# FireCrawl
# API gerida. Free tier chega para a v1.
FIRECRAWL_API_KEY=

# fal (fotos: GPT Image 2)
# Modelos:
#   openai/gpt-image-2       -> gerar do zero
#   openai/gpt-image-2/edit  -> melhorar fotos reais
FAL_KEY=

# GLM-5.2
# API HTTP direta do OpenCode Zen.
OPENCODE_GO_API_KEY=

# Opcionais
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# GLM_MODEL=glm-5.2

# App
PORT=3010

# Pasta onde vivem os leads no disco do VPS.
LEADS_DIR=./leads

# Pasta das regras (.md) lidas a cada geracao.
RULES_DIR=./rules

# Skills de prompt por slot. Cada nome corresponde a rules/skills/<nome>.md.
PROMPT_SKILLS_BY_SLOT=2:storybrand;3:copywriter
