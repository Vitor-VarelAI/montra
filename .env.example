# Montra — variáveis de ambiente (exemplo). Copia para .env e preenche.
# NUNCA committar o .env real.

# --- FireCrawl (extração) ---
# API gerida. Free tier (1.000 créditos one-time) chega para a v1.
FIRECRAWL_API_KEY=

# --- fal (fotos: GPT Image 2) ---
# Chave já existente noutros projetos. Modelos:
#   openai/gpt-image-2        -> gerar do zero (text-to-image, recurso)
#   openai/gpt-image-2/edit   -> melhorar fotos reais (caminho preferido)
FAL_KEY=

# --- GLM-5.2 (geração das 3 versões) ---
# API HTTP direta do OpenCode Zen (endpoint compatível com OpenAI).
# Não passa pelo Hermes nem por nenhum agente em runtime.
OPENCODE_GO_API_KEY=
# Opcionais (têm defaults no código):
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# GLM_MODEL=glm-5.2

# --- App ---
PORT=3010
# Pasta onde vivem os leads no disco do VPS.
LEADS_DIR=./leads
# Pasta das regras (.md) lidas a cada geração.
RULES_DIR=./rules
