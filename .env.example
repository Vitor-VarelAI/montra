# Prisma — variáveis de ambiente (exemplo). Copia para .env e preenche.
# NUNCA committar o .env real.

# --- FireCrawl (extração) ---
# API gerida. Free tier (1.000 créditos one-time) chega para a v1.
FIRECRAWL_API_KEY=

# --- fal (fotos: GPT Image 2) ---
# Chave já existente noutros projetos. Modelos:
#   openai/gpt-image-2        -> gerar do zero (text-to-image, recurso)
#   openai/gpt-image-2/edit   -> melhorar fotos reais (caminho preferido)
FAL_KEY=

# --- GLM-5.2 (geração das 6 versões) ---
# Corre via OpenCode/Hermes, reutiliza o acesso existente.
# Se a app falar com o GLM diretamente em vez de via Hermes, definir aqui.
# GLM_API_KEY=
# OPENCODE_ENDPOINT=

# --- App ---
PORT=3000
# Pasta onde vivem os leads no disco do VPS.
LEADS_DIR=./leads
